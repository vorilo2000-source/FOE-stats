function renderProgressSection() {
  if (state.snapshots.length < 1) return;
  const wrap = document.getElementById('sparklineWrap');
  const sorted = [...state.players].sort((a,b) => b.points - a.points);

  wrap.innerHTML = sorted.slice(0, 12).map(player => {
    const history = state.snapshots.map(snap => {
      const found = snap.players.find(p => p.name === player.name);
      return found ? found.points : 0;
    });
    const latest = history[history.length - 1];
    const first = history[0];
    const growth = latest - first;
    return `<div class="sparkline-card">
      <div class="sparkline-header">
        <div>
          <div class="sparkline-name">${esc(player.name)}</div>
          <div style="font-size:0.75rem;color:var(--text-muted)">${esc(player.era)}</div>
        </div>
        <div>
          <div class="sparkline-total">${fmt(latest)}</div>
          <div style="font-size:0.75rem;color:${growth >= 0 ? 'var(--green)' : 'var(--red)'}">${growth >= 0 ? '+' : ''}${fmt(growth)}</div>
        </div>
      </div>
      <canvas class="sparkline" id="spark-${player.name.replace(/\s/g,'_')}" data-history="${history.join(',')}"></canvas>
    </div>`;
  }).join('');

  // Draw sparklines
  setTimeout(() => {
    document.querySelectorAll('canvas.sparkline').forEach(canvas => {
      const data = canvas.dataset.history.split(',').map(Number);
      drawSparkline(canvas, data);
    });
  }, 50);
}

function drawSparkline(canvas, data) {
  const rect = canvas.getBoundingClientRect();
  const w = rect.width || 260;
  const h = 48;
  canvas.width = w * window.devicePixelRatio;
  canvas.height = h * window.devicePixelRatio;
  const ctx = canvas.getContext('2d');
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  if (data.length < 2) {
    ctx.fillStyle = 'rgba(201,168,76,0.3)';
    ctx.beginPath(); ctx.arc(w/2, h/2, 4, 0, Math.PI*2); ctx.fill();
    return;
  }
  const min = Math.min(...data), max = Math.max(...data);
  const range = max - min || 1;
  const pts = data.map((v, i) => ({
    x: (i / (data.length - 1)) * w,
    y: h - 4 - ((v - min) / range) * (h - 8)
  }));
  // Fill
  const grad = ctx.createLinearGradient(0, 0, 0, h);
  grad.addColorStop(0, 'rgba(201,168,76,0.25)');
  grad.addColorStop(1, 'rgba(201,168,76,0)');
  ctx.beginPath();
  ctx.moveTo(pts[0].x, h);
  pts.forEach(p => ctx.lineTo(p.x, p.y));
  ctx.lineTo(pts[pts.length-1].x, h);
  ctx.closePath();
  ctx.fillStyle = grad; ctx.fill();
  // Line
  ctx.beginPath();
  ctx.moveTo(pts[0].x, pts[0].y);
  pts.forEach(p => ctx.lineTo(p.x, p.y));
  ctx.strokeStyle = '#c9a84c';
  ctx.lineWidth = 2;
  ctx.lineJoin = 'round';
  ctx.stroke();
  // Dot
  const last = pts[pts.length-1];
  ctx.beginPath();
  ctx.arc(last.x, last.y, 3.5, 0, Math.PI*2);
  ctx.fillStyle = '#e8c97a'; ctx.fill();
}

