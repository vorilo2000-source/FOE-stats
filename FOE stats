<script>
// ──────────────────────────────────────────────
// STATE
// ──────────────────────────────────────────────
let state = {
  players: [],
  guildName: '',
  world: '',
  gbg: {},
  snapshots: [],
  lastUpdated: null
};

let pendingPlayers = [];

// ──────────────────────────────────────────────
// NAVIGATION
// ──────────────────────────────────────────────
function showPage(id, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
}

function switchSubTab(section, tab, btn) {
  btn.closest('.sub-tabs').querySelectorAll('.sub-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  if (section === 'players') renderPlayersTable(tab);
}

// ──────────────────────────────────────────────
// IMPORT MODAL
// ──────────────────────────────────────────────
function openImport() { document.getElementById('importModal').classList.add('open'); }
function closeImport() { document.getElementById('importModal').classList.remove('open'); }

function switchImportTab(tab, btn) {
  document.querySelectorAll('.import-tab').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.import-pane').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('pane-' + tab).classList.add('active');
}

function addPlayerManual() {
  const name = document.getElementById('f-pname').value.trim();
  if (!name) { alert('Vul een spelernaam in.'); return; }
  const player = {
    name,
    era: document.getElementById('f-era').value,
    points: parseInt(document.getElementById('f-points').value) || 0,
    battles: parseInt(document.getElementById('f-battles').value) || 0,
    gbg_battles: parseInt(document.getElementById('f-gbg').value) || 0,
    role: document.getElementById('f-role').value,
    fps_contributed: 0,
    goods: 0,
    great_buildings: []
  };
  pendingPlayers.push(player);
  renderPendingList();
  document.getElementById('f-pname').value = '';
  document.getElementById('f-points').value = '';
  document.getElementById('f-battles').value = '';
  document.getElementById('f-gbg').value = '';
}

function renderPendingList() {
  const el = document.getElementById('playerList');
  if (!pendingPlayers.length) { el.innerHTML = ''; return; }
  el.innerHTML = pendingPlayers.map((p, i) =>
    `<div style="display:flex;justify-content:space-between;align-items:center;padding:0.4rem 0.75rem;background:var(--bg-dark);border-radius:4px;margin-bottom:0.4rem;font-size:0.85rem">
      <span><strong>${p.name}</strong> <span style="color:var(--text-muted)">${p.era}</span></span>
      <span style="color:var(--gold-light);font-family:'Barlow Condensed',sans-serif;font-weight:700">${fmt(p.points)} pts</span>
      <button onclick="pendingPlayers.splice(${i},1);renderPendingList()" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:1rem;padding:0 0.25rem">×</button>
    </div>`
  ).join('');
}

function handleFileUpload(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => { document.getElementById('f-json').value = e.target.result; };
  reader.readAsText(file);
}

function importData() {
  const activeTab = document.querySelector('.import-tab.active').textContent.trim();

  if (activeTab === 'Handmatig') {
    if (pendingPlayers.length === 0) { alert('Voeg eerst spelers toe.'); return; }
    const gn = document.getElementById('f-guild-name').value.trim();
    const wd = document.getElementById('f-world').value.trim();
    if (gn) state.guildName = gn;
    if (wd) { state.world = wd; document.getElementById('worldBtn').textContent = '🌍 ' + wd; }
    state.players = [...state.players, ...pendingPlayers];
    pendingPlayers = [];
    renderPendingList();
  } else if (activeTab === 'JSON / FoE Helper') {
    try {
      const raw = document.getElementById('f-json').value.trim();
      const parsed = JSON.parse(raw);
      const players = Array.isArray(parsed) ? parsed : parsed.players || [];
      if (parsed.guild) state.guildName = parsed.guild;
      if (parsed.world) { state.world = parsed.world; document.getElementById('worldBtn').textContent = '🌍 ' + parsed.world; }
      state.players = [...state.players, ...players];
    } catch(e) { alert('Ongeldige JSON: ' + e.message); return; }
  } else if (activeTab === 'CSV Plakken') {
    const csv = document.getElementById('f-csv').value.trim();
    const rows = csv.split('\n').map(r => r.split('\t'));
    const headers = rows[0].map(h => h.trim().toLowerCase());
    const players = rows.slice(1).map(row => {
      const obj = {};
      headers.forEach((h, i) => obj[h] = row[i]?.trim() || '');
      return {
        name: obj['naam'] || obj['name'] || 'Onbekend',
        era: obj['era'] || '—',
        points: parseInt((obj['punten'] || obj['points'] || '0').replace(/\D/g,'')) || 0,
        battles: parseInt((obj['gevechten'] || obj['battles'] || '0').replace(/\D/g,'')) || 0,
        gbg_battles: parseInt((obj['gbg'] || obj['gbg_gevechten'] || '0').replace(/\D/g,'')) || 0,
        role: obj['rol'] || obj['role'] || 'Lid',
        fps_contributed: parseInt((obj['fp_bijdrage'] || '0').replace(/\D/g,'')) || 0,
        goods: parseInt((obj['goederen'] || obj['goods'] || '0').replace(/\D/g,'')) || 0,
        great_buildings: []
      };
    }).filter(p => p.name !== 'Onbekend' || true);
    state.players = [...state.players, ...players];
  }

  state.lastUpdated = new Date();
  // Save snapshot for progress
  state.snapshots.push({ date: state.lastUpdated.toLocaleDateString('nl-NL'), players: JSON.parse(JSON.stringify(state.players)) });

  closeImport();
  renderAll();
}

